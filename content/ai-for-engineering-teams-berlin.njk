			"name": "Matt Richards",
			"jobTitle": "Freelance Tech Lead",
			"url": "{{ metadata.url }}/",
			"email": "mailto:hallo@tthew.berlin",
			"image": "{{ metadata.url }}/img/1564326180592.jpeg",
			"sameAs": [
				"https://hachyderm.io/@tthew",
				"https://www.linkedin.com/in/tthew/",
				"https://github.com/tthew"
			],
			"address": { "@type": "PostalAddress", "addressLocality": "Berlin", "addressCountry": "DE" }
		},
		{
			"@type": "ProfessionalService",
			"@id": "{{ metadata.url }}{{ page.url }}#service",
			"name": "Matt Richards — AI for Engineering Teams, Berlin",
			"description": "AI adoption for software engineering teams: workflow design, guardrails, hiring, review practices, and team health. For engineering orgs using AI every day without rotting the codebase.",
