				{ "@type": "City", "name": "Berlin" },
				{ "@type": "Country", "name": "Germany" },
				{ "@type": "Place", "name": "European Union" },
				{ "@type": "Place", "name": "Remote" }
			],
			"serviceType": [
				"AI adoption consultant",
				"AI engineering advisor",
				"AI for engineering teams",
				"AI coding workflow consultant",
