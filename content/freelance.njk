		{
			"@type": "Person",
			"@id": "{{ metadata.url }}/#matt",
			"name": "Matt Richards",
			"jobTitle": "Freelance Senior+ Product Engineer",
			"description": "Freelance senior+ product engineer in Berlin, available for web, frontend and software engineering engagements as well as engineering leadership.",
			"url": "{{ metadata.url }}/",
			"email": "mailto:hallo@tthew.berlin",
			"image": "{{ metadata.url }}/img/1564326180592.jpeg",
			"sameAs": [
				"https://hachyderm.io/@tthew",
				"https://www.linkedin.com/in/tthew/",
				"https://github.com/tthew"
			],
