---
import colors from "../design-tokens/colors.json";
import fonts from "../design-tokens/fonts.json";
import spacing from "../design-tokens/spacing.json";
import textSizes from "../design-tokens/text-sizes.json";
import { clampGenerator } from "../utils/clamp-generator";
import { tokensToCustomProperties } from "../utils/tokens-to-custom-properties";

const customProperties = [
  ...tokensToCustomProperties(colors.items, "color"),
  ...tokensToCustomProperties(clampGenerator(spacing.items), "space"),
  ...tokensToCustomProperties(clampGenerator(textSizes.items)),
  ...tokensToCustomProperties(fonts.items, "font"),
].join("\n    ");

const designTokens = `
:root {
  	${customProperties}
}
`;
---

<style type="text/css" is:inline set:text={designTokens}></style>

<style is:global>
  /*
  The CSS in this style tag is based off of Bear Blog's default CSS.
  https://github.com/HermanMartinus/bearblog/blob/297026a877bc2ab2b3bdfbd6b9f7961c350917dd/templates/styles/blog/default.css
  License MIT: https://github.com/HermanMartinus/bearblog/blob/master/LICENSE.md
 */

  :root {
    --dark: hsl(163, 60%, 6%);
    --light: hsl(251, 93%, 78%);
    /* color-scheme: light dark; */
    --bg: var(--light);
    --fg: var(--dark);
    /* animation: morph auto linear; */
  }
  /* @media (prefers-color-scheme: dark) { */
  :root {
    --bg: var(--dark);
    --fg: var(--light);
  }
  /* } */
  html {
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    -webkit-font-smoothing: auto;
    -moz-osx-font-smoothing: auto;
    scroll-behavior: smooth;
    min-height: 100%;
  }

  body {
    display: flex;
    flex-direction: column;
    font-family: var(--font-medium);
    font-size: var(--step-0);
    scrollbar-gutter: stable;
    /* padding: var(--space-s); */
    margin: 0;
    background: var(--bg);
    color: #fff;
    /* animation: 1s morph linear; */
    animation-timeline: --page-scroll;
    overflow-x: hidden;
    background: radial-gradient(circle at 50% 10%, var(--bg), var(--fg));
    min-height: 100%;
  }

  html:has(header input:checked) html,
  html:has(header input:checked) body {
    overflow: hidden;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6,
  strong,
  b {
    /* color: #222; */
  }
  a {
    /* color: #3273dc; */
  }
  nav a {
    margin-right: 10px;
  }
  textarea {
    width: 100%;
    font-size: 16px;
  }
  input {
    font-size: 16px;
  }
  content {
    line-height: 1.6;
  }
  table {
    width: 100%;
  }
  img {
    max-width: 100%;
    height: auto;
  }
  code {
    padding: 2px 5px;
    background-color: #f2f2f2;
  }
  pre {
    padding: 1rem;
  }
  pre > code {
    all: unset;
  }
  blockquote {
    /* color: #222; */
    margin: 0px;
    /* font-style: italic; */
    font-weight: 200;
  }

  #main {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h1 {
    font-size: var(--step-5);
    line-height: var(--step-5);
    font-weight: 900;
    margin: 0;
  }

  p {
    /* font-size: var(--step-1); */
    margin-bottom: var(--space-s);
  }

  main > * + * {
    column-gap: var(--space-l);
    row-gap: var(--space-l);
  }
  /* 

  h2 {
    font-size: var(--step-4);
  }

  h3 {
    font-size: var(--step-3);
  }

  h5 {
    font-size: var(--step-2);
  }

  h6 {
    font-size: var(--step-1);
  }


  */
  .sr-only:not(:focus):not(:active) {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  hr {
    margin-top: 2rem;
    border-top: 1px solid #ddd;
  }

  a:link,
  a:visited {
    color: currentColor;
    /* text-decoration: none; */
  }

  /* @link https://utopia.fyi/type/calculator?c=320,18,1.2,1240,20,1.25,5,2,&s=0.75|0.5|0.25,1.5|2|3|4|6,s-l&g=s,l,xl,12 */
</style>
