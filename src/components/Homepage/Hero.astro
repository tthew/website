---

import { Image } from "@astrojs/image/components";
import { SITE_DESCRIPTION } from "../../consts";
import mePic from './me.jpg';


const heroText = SITE_DESCRIPTION.split(" ");
const widths = [256];
---

<div class="hero">
  <h1>
    <a href="#top">Senior+ Software Engineering Lead Berlin</a>
  </h1>
  <div class="hero-intro">
    <div class="pic">
      <Image src={mePic} format="webp"  widths={[mePic.width]}
  sizes={`(max-width: 360px) 128w, (max-width: 720px) 256w, (max-width: 1600px) 512w, ${mePic.width}w`}
 alt="A Picture of 256!" />
    </div>
    <blockquote>
      {SITE_DESCRIPTION}
    </blockquote>
  </div>
</div>

