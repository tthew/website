---
import { SITE_DESCRIPTION } from "../../consts";

const heroText = SITE_DESCRIPTION.split(" ");
---

<div class="hero">
  <h1>
    <a href="#top">Senior+ Software Engineering Lead Berlin</a>
  </h1>
  <blockquote>
    {heroText.map((word, index: number) => <span class="word">{word} </span>)}
  </blockquote>
</div>

<style>
  @keyframes bounce {
    0%,
    100% {
      -webkit-transform: translateY(0);
    }
    50% {
      -webkit-transform: translateY(-10px);
    }
  }

  @keyframes fadeOut {
    0% {
      opacity: 1;
    }

    26% {
      opacity: 0;
    }

    100% {
      opacity: 0;
    }
  }

  .hero {
    flex: 1 0 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    row-gap: var(--space-l);
    justify-content: center;
    animation: fadeOut auto linear;
    padding: 0 var(--space-s);
    animation-timeline: --page-scroll;
  }

  .hero::after {
    flex: 1;
    display: flex;
    align-items: center;
    content: "↓";
    font-size: var(--step-3);
    animation: bounce 0.5s 3;
  }

  .hero h1 {
    display: flex;
    flex: 1 0 auto;
    text-align: center;
    text-wrap: balance;
    align-items: flex-end;
  }

  .hero h1 a:link,
  .hero h1 a:visited {
    text-decoration: none;
  }

  blockquote {
    flex: 0 1 auto;
    font-size: var(--step-1);
    padding: var(--space-s);
    text-align: center;
    text-wrap: pretty;
    white-space: pre-line;
  }

  @media screen and (min-width: 420px) {
    .hero {
      max-width: 75%;
    }
  }

  @media screen and (min-width: 1920px) {
    .hero h1 {
      font-size: var(--step-6);
      line-height: var(--step-6);
    }

    blockquote {
      max-width: 75%;
      font-size: var(--step-2);
    }
  }
</style>
